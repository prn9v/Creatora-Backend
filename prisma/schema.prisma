generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  email             String          @unique
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  /// *
  ///    * Profile info
  name              String?
  id                String          @id @default(uuid())
  bio               String?
  creditsLimit      Int             @default(50)
  creditsUsed       Int             @default(0)
  /// *
  ///    * Account state
  isActive          Boolean         @default(true)
  password          String
  /// *
  ///    * Account & plan
  plan              Plan            @default(FREE)
  profileImageUrl   String?
  /// *
  ///    * Password Reset OTP
  resetOtp          String?
  resetOtpExpiresAt DateTime?       @map("reset_otp_expires_at")
  brandProfile      BrandProfile?
  contentIdeas      ContentIdea[]
  generatedPosts    GeneratedPost[]
  pastPosts         PastPost[]
  socialAccounts    SocialAccount[]
  weeklyPlans       WeeklyPlan[]
}

model BrandProfile {
  id                   String   @id @default(uuid())
  niche                String?
  audience             String?
  /// *
  ///    * AI generated
  styleSummary         String?
  userId               String   @unique
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
  /// *
  ///    * Writing style analysis
  avgSentenceLength    Float?
  commonPhrases        Json?
  emotionalTone        String?
  /// *
  ///    * Voice characteristics
  formalityScore       Float?
  humorUsage           Boolean  @default(false)
  storytellingStyle    String?
  topicPreferences     Json?
  vocabularyComplexity String?
  tone                 Tone?
  user                 User     @relation(fields: [userId], references: [id])
}

model SocialAccount {
  id            String         @id @default(uuid())
  platform      SocialPlatform
  username      String?
  /// *
  ///    * Account metrics
  followers     Int?
  engagement    Float?
  postFrequency String?
  /// *
  ///    * Platform-specific data
  metadata      Json?
  /// *
  ///    * Account status
  isConnected   Boolean        @default(false)
  lastSynced    DateTime?
  userId        String
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  user          User           @relation(fields: [userId], references: [id])

  @@unique([userId, platform])
}

model PastPost {
  id        String   @id @default(uuid())
  /// *
  ///    * Optional AI embedding
  content   String
  userId    String
  createdAt DateTime @default(now())
  analysis  Json?
  author    String?
  mediaUrl  String?
  metadata  Json?
  platform  String?
  type      String?
  updatedAt DateTime @updatedAt
  url       String?
  user      User     @relation(fields: [userId], references: [id])
}

model ContentIdea {
  id          String  @id @default(uuid())
  title       String
  hook        String?
  description String? // 60-100 words explaining the idea or trend meaning
  format      String? // Reel | Carousel | Talking-head | BTS | Trend hijack | Story/Poll
  angle       String?
  cta         String?
  platform    String?
  source      String? // AI | TRENDING
  trendSource String? // Reddit | YouTube | Instagram
  trendTitle  String?
  isFavorite  Boolean @default(false)

  userId String
  user   User   @relation(fields: [userId], references: [id])

  generatedPosts GeneratedPost[]

  createdAt DateTime @default(now())
}

model GeneratedPost {
  id           String       @id @default(uuid())
  content      String
  platform     String
  sourceIdeaId String?
  userId       String
  createdAt    DateTime     @default(now())
  sourceIdea   ContentIdea? @relation(fields: [sourceIdeaId], references: [id])
  user         User         @relation(fields: [userId], references: [id])
}

model WeeklyPlan {
  id        String   @id @default(uuid())
  weekStart DateTime
  plan      Json
  userId    String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
}

enum Plan {
  FREE
  CREATOR
  PRO
}

enum Tone {
  PROFESSIONAL
  CASUAL
  INSPIRING
  EDUCATIONAL
}

enum SocialPlatform {
  TWITTER
  LINKEDIN
  INSTAGRAM
  FACEBOOK
  YOUTUBE
  BLOG
  EMAIL
  THREAD
}
